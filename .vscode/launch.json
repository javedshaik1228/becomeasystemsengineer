{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NetForge server (Linux/WSL · GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/vscode-work/netforge-server",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "NetForge: Build work"
    },
    {
      "name": "NetForge server (macOS · CodeLLDB)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/vscode-work/netforge-server",
      "args": [],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated",
      "preLaunchTask": "NetForge: Build work"
    }
  ]
}
